{
  "schemaVersion": "nextop.app.manifest.v1",
  "appId": "automation",
  "version": "0.1.0",
  "name": "Automation",
  "description": "Schedule and review recurring automation runs.",
  "icon": {
    "type": "asset",
    "src": "icon.png"
  },
  "runtime": {
    "bootstrap": "bootstrap.sh",
    "healthcheckPath": "/healthz"
  },
  "window": {
    "minWidth": 800,
    "minHeight": 500
  },
  "cli": {
    "manifest": "nextop.cli.json"
  },
  "author": {
    "name": "Nextop"
  },
  "tags": ["automation", "workspace"],
  "localizationInfo": {
    "defaultLocale": "en",
    "additionalLocales": [
      {
        "locale": "zh-CN",
        "file": "locales/zh-CN/manifest.json"
      }
    ]
  }
}
