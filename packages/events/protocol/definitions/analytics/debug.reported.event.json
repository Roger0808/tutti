{
  "$schema": "../../schemas/core/event-definition.schema.json",
  "topic": "analytics.debug.reported",
  "version": 1,
  "direction": "server->client",
  "owner": "desktop",
  "scope": "desktop",
  "payloadSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["events"],
    "properties": {
      "events": {
        "type": "array",
        "minItems": 1,
        "maxItems": 100,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "clientTs", "params"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "clientTs": {
              "type": "integer",
              "minimum": 1
            },
            "params": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
