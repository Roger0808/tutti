      },
      "issueId": {
        "type": "string",
        "minLength": 1
      },
      "taskId": {
        "type": "string",
        "minLength": 1
      },
      "runId": {
        "type": "string",
        "minLength": 1
      },
      "changeKind": {
        "type": "string",
        "enum": [
          "issue_created",
          "issue_updated",
          "issue_deleted",
          "issue_context_refs_updated",
          "task_created",
          "task_updated",
          "task_deleted",
